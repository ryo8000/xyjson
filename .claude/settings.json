{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(npm install)",
      "Bash(npm run compile)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run copy-fixtures)",
      "Bash(npm test)",
      "Bash(npm run test:integration)",
      "Bash(npm run vscode:package)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(npm install *)",
      "Bash(npm run vscode:publish)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf /*)",
      "Bash(sudo *)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "enableAllProjectMcpServers": false
}
