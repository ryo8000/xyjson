{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Skill(prepare-release)",
      "Skill(update-changelog)",
      "Skill(verify)",
      "Bash(git add *)",
      "Bash(git diff *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git ls-files *)",
      "Bash(git show *)",
      "Bash(git status)",
      "Bash(git tag -l *)",
      "Bash(npm audit)",
      "Bash(npm install)",
      "Bash(npm ls *)",
      "Bash(npm run check-types)",
      "Bash(npm run compile)",
      "Bash(npm run compile-tests)",
      "Bash(npm run copy-fixtures)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run package)",
      "Bash(npm run test:integration)",
      "Bash(npm run vscode:package)",
      "Bash(npm test)",
      "Bash(npm view *)"
    ],
    "ask": [
      "Bash(git clean)",
      "Bash(git clean *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git reset)",
      "Bash(git reset *)",
      "Bash(node -e *)",
      "Bash(npm install *)",
      "Bash(npm run vscode:publish)",
      "Bash(npm version *)"
    ],
    "deny": [
      "Bash(rm -fr *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)"
    ]
  },
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/post-edit-lint.js"],
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm test",
            "statusMessage": "Validating: npm test...",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
