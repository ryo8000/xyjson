{
  "name": "xyjson",
  "displayName": "XYJson - XML YAML JSON Converter",
  "description": "Convert between XML, YAML, and JSON. Pretty-print or minify your data. Supports converting selected text only.",
  "version": "0.1.0",
  "author": "Ryo Hasegawa",
  "publisher": "ryo8000",
  "icon": "icon.png",
  "license": "MIT",
  "repository": "https://github.com/ryo8000/xyjson.git",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "keywords": [
    "json",
    "xml",
    "yaml",
    "yml",
    "converter",
    "formatter",
    "minify",
    "pretty print",
    "indent",
    "json formatter",
    "xml formatter",
    "yaml formatter",
    "json to xml",
    "xml to json",
    "json to yaml",
    "yaml to json",
    "xml to yaml",
    "yaml to xml",
    "json yaml converter",
    "xml json converter",
    "xml yaml converter"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "xyjson.toJson",
        "title": "XYJson: Convert to JSON"
      },
      {
        "command": "xyjson.toXml",
        "title": "XYJson: Convert to XML"
      },
      {
        "command": "xyjson.toYaml",
        "title": "XYJson: Convert to YAML"
      },
      {
        "command": "xyjson.formatJson",
        "title": "XYJson: Format JSON"
      },
      {
        "command": "xyjson.formatXml",
        "title": "XYJson: Format XML"
      },
      {
        "command": "xyjson.formatYaml",
        "title": "XYJson: Format YAML"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "xyjson.toJson",
          "when": "editorLangId == xml || editorLangId == yaml"
        },
        {
          "command": "xyjson.toXml",
          "when": "editorLangId == json || editorLangId == jsonc || editorLangId == yaml"
        },
        {
          "command": "xyjson.toYaml",
          "when": "editorLangId == json || editorLangId == jsonc || editorLangId == xml"
        },
        {
          "command": "xyjson.formatJson",
          "when": "editorLangId == json || editorLangId == jsonc"
        },
        {
          "command": "xyjson.formatXml",
          "when": "editorLangId == xml"
        },
        {
          "command": "xyjson.formatYaml",
          "when": "editorLangId == yaml"
        }
      ],
      "editor/context": [
        {
          "command": "xyjson.toJson",
          "group": "xyjson",
          "when": "editorLangId == xml || editorLangId == yaml"
        },
        {
          "command": "xyjson.toXml",
          "group": "xyjson",
          "when": "editorLangId == json || editorLangId == jsonc || editorLangId == yaml"
        },
        {
          "command": "xyjson.toYaml",
          "group": "xyjson",
          "when": "editorLangId == json || editorLangId == jsonc || editorLangId == xml"
        },
        {
          "command": "xyjson.formatJson",
          "group": "xyjson",
          "when": "editorLangId == json || editorLangId == jsonc"
        },
        {
          "command": "xyjson.formatXml",
          "group": "xyjson",
          "when": "editorLangId == xml"
        },
        {
          "command": "xyjson.formatYaml",
          "group": "xyjson",
          "when": "editorLangId == yaml"
        }
      ]
    },
    "configuration": {
      "properties": {
        "xyjson.indentSize": {
          "type": "integer",
          "default": 2,
          "minimum": 1,
          "maximum": 8,
          "description": "Number of spaces used for indentation when pretty-formatting XML/YAML/JSON output."
        },
        "xyjson.xmlAttributeNamePrefix": {
          "type": "string",
          "default": "@_",
          "description": "Prefix added to XML attribute names when parsing or building XML."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "copy-fixtures": "node ./scripts/copy-fixtures.js",
    "lint": "eslint src",
    "pretest": "npm run compile && npm run copy-fixtures && npm run lint",
    "test": "mocha --ui tdd 'out/test/unit/**/*.test.js'",
    "pretest:integration": "npm run pretest",
    "test:integration": "vscode-test"
  },
  "dependencies": {
    "fast-xml-parser": "5.7.1",
    "js-yaml": "4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/mocha": "10.0.10",
    "@types/node": "25.x",
    "@types/vscode": "1.116.0",
    "@vscode/test-cli": "0.0.12",
    "@vscode/test-electron": "2.5.2",
    "eslint": "10.2.1",
    "mocha": "11.7.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0"
  }
}
